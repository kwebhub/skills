        code.
          // Declaration
          mixin pet(name)
            li.pet= name
          // use
          ul                                              
            +pet('cat')
            +pet('dog')
            +pet('pig') 

          mixin article(title)
            .article
              .article-wrapper
                h1= title
                if block
                  block
                else
                  p No content provided
          +article('Hello world')
          +article('Hello world')
            p This is my
            p Amazing article

          mixin link(href, name)
          // attributes == {class: "btn"}
            a(class!=attributes.class href=href)= name

          +link('/foo', 'foo')(class="btn")

