          p.
            plugins/
          p Создать блок
          code npx @wordpress/create-block kweblock --namespace=kweb --variant=dynamic

          p Автоформат добавить в package.json
          code "prettier": "@wordpress/prettier-config"

          p Создать файл webpack.config.js и добавить свой код для выполнения webpack
          code.
            const defaultConfig = require("@wordpress/scripts/config/webpack.config");

            var config = {
              ...defaultConfig,
              entry: {
                ...defaultConfig.entry(),
                "custom/index": "./src/custom/index.js",
              },
            };

          p.
            Внутри папки src создать папку custom и в ней файл index.js
            Для примера отменим регистрацию блока core/verse при компиляции webpack
          code.
            import { unregisterBlockType } from "@wordpress/blocks";
            import domReady from "@wordpress/dom-ready";

            const unregisterBlocks = ["core/verse"];

            domReady(function () {
              unregisterBlocks.forEach(block) => {
                unregisterBlockType(block);
              });
            });

          p В файле kweblock.php добавить код для подключения функционала из custom/index.js
          code.
            function kweblock_enqueue_editor_modifications() {
              $asset_file = include plugin_dir_path( __FILE__ ) . 'build/custom/index.assets.php';
            
              wp_enqueue_script(
                'kweblock_enqueue_editor_modifications',
                plugins_url( '/build/custom/index.js', __FILE__ ),
                $asset_file['dependencies'],
                $asset_file['version'],
                true
              );
            }
            add_action( 'enqueue_block_editor_assets', 'kweblock_enqueue_editor_modifications' );

          p Внутри папки scr создать папку kweblock_1 и переместить в неё содержимое папки src

          p Перейти в папку src и добавить ещё блок
          code npx @wordpress/create-block kweblock_2 --no-plugin --namespace=kweb1 --variant=dynamic

          p В файле kweblock.php
          code.
            function kweb_kweblock_block_init() {
              register_block_type( __DIR__ . '/build/kweblock_1' );
              register_block_type( __DIR__ . '/build/kweblock_2' );
            }
            add_action( 'init', 'kweb_kweblock_block_init' );

          p.
            В терминале npm start
            В панели администратора активировать плагин

          p.
            edit.js - пишем весь функционал блока и компоненты react для вывода в редакторе
            render.php - пишем код динамического фронтенда. Обновляет фронтенд динамически.
            save.js - пишем весь функционал блока как в edit.js, но без компонентов react. Сохранит разметку html в базу данных для вывода на фронтенд.

            index.js - отвечает за вызов registerBlockType(), импортирует файлы edit.js и save.js
            свойствo edit = компонент react из edit.js
            свойствo save = статическая html-разметка из save.js

            регистрация на сервере (файл_плагина.php)
          pre
            code.
              function my_custom_block___register_block() {
                  register_block_type( __DIR__ . '/build' );
              }
              add_action( 'init', 'my_custom_block___register_block' ); 
          p регистрация на клиенте (index.js)
          pre
            code.
              import { registerBlockType } from '@wordpress/blocks';
              import { useBlockProps } from '@wordpress/block-editor';
              import metadata from './block.json';

              const Edit = () => &lt;p { ...useBlockProps() }&gt;Hello World - Block Editor&lt;/p&gt;;
              const save = () => &lt;p { ...useBlockProps.save() }&gt;Hello World - Frontend&lt;/p&gt;;

              registerBlockType( metadata.name, {
                  edit: Edit,
                  save,
              } );
          p.
            useBlockProps() - edit.js, включениe дополнительных классов и атрибутов в разметку блока в редакторе, передавая их в качестве аргументов<br>
            useBlockProps.save() - save.js, в html разметку фронтенда добавляются классы при добавлении supports<br>
            get_block_wrapper_attributes() - render.php, в динамический фронтенд добавляются классы и аттрибуты<br>

            Пакет @wordpress/scripts настраивает webpack и Babel
            Пакет @wordpress/components включает библиотеку общих компонентов WordPress для создания общих элементов пользовательского интерфейса для редактора блоков и панели управления WordPress.<br>
            Пакет @wordpress/block-editor включает библиотеку компонентов и хуков для редактора блоков, включая те, которые определяют пользовательские настройки элементов управления для блока.<br>
            - attributes: Объект всех атрибутов блока.<br>
            - setAttributes: Метод обновления объекта атрибутов.<br>
            - isSelected: Логическое значение, указывающее, выбран ли блок в данный момент.<br>

            BlockControls - компонент react, отображает панель инструментов блока в редакторе.<br>
            InspectorControls - компонент react, отображает панель настроек блока в редакторе.<br>

            wp:image - блоки ядра
            wp:namespace/name - пользовательские блоки

            wp_enqueue_style() - добавляет стили в очередь для загрузки на странице.<br>
            wp_enqueue_script() - добавляет скрипт в очередь для загрузки на странице.<br>
            wp_localize_script() - добавляет данные JavaScript в объект window.<br>
            цепляем на хуки:<br>
            enqueue_block_editor_assets – загружать только в режиме редактора<br>
            enqueue_block_assets – загружается как в интерфейсе, так и в редакторе<br>
          pre
            code.
              <span>Block in theme</span>
              add_action(
                'enqueue_block_editor_assets', 
                function() {
                  wp_enqueue_script(
                    'my-custom-block-editor',
                    get_template_directory_uri() . '/blocks/my-custom-block/index.js',
                    array( 'wp-blocks', 'wp-element', 'wp-editor' ),
                    filemtime( get_template_directory() . '/blocks/my-custom-block/index.js' )
                  );
                  wp_enqueue_style(
                    'my-custom-block-editor',
                    get_template_directory_uri() . '/blocks/my-custom-block/index.css',
                    array( 'wp-edit-blocks' ),
                    filemtime( get_template_directory() . '/blocks/my-custom-block/index.css' )
                  );
                });
              <span>Block in plugin</span>
              add_action(
                'enqueue_block_editor_assets', 
                function() {
                  wp_enqueue_script(
                    'my-custom-block-editor',
                    plugins_url( 'blocks/my-custom-block/index.js', __FILE__ ),
                    array( 'wp-blocks', 'wp-element', 'wp-editor' ),
                    filemtime( plugin_dir_path( __FILE__ ) . 'blocks/my-custom-block/index.js' )
                  );
                  wp_enqueue_style(
                    'my-custom-block-editor',
                    plugins_url( 'blocks/my-custom-block/index.css', __FILE__ ),
                    array( 'wp-edit-blocks' ),
                    filemtime( plugin_dir_path( __FILE__ ) . 'blocks/my-custom-block/index.css' )
                  );
                });

